# Backend configuration (read by python-decouple from this file or the env).
# Copy to `.env` and fill in real values. `.env` must never be committed.

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True

# Telegram bot — calendar event reminders.
# Create the bot with @BotFather; the token is a secret.
TELEGRAM_BOT_TOKEN=
# The bot's @username (without the @), used to build the t.me connect link.
TELEGRAM_BOT_USERNAME=
# false: receive updates by long-polling (run `manage.py run_telegram_bot`) — good for dev.
# true:  receive updates by webhook (needs a public HTTPS URL) — for production.
TELEGRAM_USE_WEBHOOK=False
# Random secret embedded in the webhook URL path; only needed when using a webhook.
TELEGRAM_WEBHOOK_SECRET=
