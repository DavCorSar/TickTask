# Production environment. Copy to `.env` and fill in real values.
# NEVER commit the real `.env`. Generate a strong secret, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
# Comma-separated hostnames this app is served on (no scheme).
DJANGO_ALLOWED_HOSTS=ticktask.example.com
# Comma-separated origins (with scheme) trusted for CSRF (the Django admin).
DJANGO_CSRF_TRUSTED_ORIGINS=https://ticktask.example.com

# --- TLS / security ---
# TLS is terminated upstream (Tailscale Funnel / your proxy), which already
# serves HTTPS, so leave the app-level redirect off to avoid a loop. Set to True
# only if nginx here terminates TLS itself.
DJANGO_SECURE_SSL_REDIRECT=False
# HSTS max-age in seconds. Start low (e.g. 3600) when first enabling, then raise.
DJANGO_HSTS_SECONDS=31536000

# --- Public access: Tailscale Funnel ---
# Auth key for the `tailscale` service (Tailscale admin console -> Settings ->
# Keys -> Generate auth key; reusable is convenient). Needed only with the
# `public` compose profile. Leave blank if you expose the app another way.
# The public URL is https://<hostname>.<your-tailnet>.ts.net, where <hostname>
# is set on the tailscale service in docker-compose.prod.yml (default: ticktask)
# -- put that full hostname in DJANGO_ALLOWED_HOSTS / DJANGO_CSRF_TRUSTED_ORIGINS
# above. Enable the Funnel feature for your tailnet first (see DEPLOY.md).
TS_AUTHKEY=

# --- CORS ---
# The SPA is served same-origin via nginx, so CORS usually isn't needed.
CORS_ALLOW_ALL_ORIGINS=False
# If you serve the frontend from a different origin, list it here (with scheme).
CORS_ALLOWED_ORIGINS=

# --- Database ---
# Persisted on the `app-data` volume mounted at /data (see compose).
DJANGO_DB_PATH=/data/db.sqlite3

# --- Cache (Telegram bot conversation state) ---
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://redis:6379/1

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# This stack runs the bot by long-polling, so leave the webhook off.
TELEGRAM_USE_WEBHOOK=False
TELEGRAM_WEBHOOK_SECRET=
